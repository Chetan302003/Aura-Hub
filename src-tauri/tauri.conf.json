{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura VTC Hub",
  "version": "1.0.0-beta.1",
  "identifier": "com.auravtc.hub",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aura VTC Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; connect-src 'self' https://*.supabase.co https://api.truckersmp.com wss://*.supabase.co; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Aura VTC",
    "copyright": "© 2024 Aura VTC",
    "category": "Utility",
    "shortDescription": "Aura VTC Hub",
    "longDescription": "Fleet management hub for Euro Truck Simulator 2 VTC"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBRTkyNzVERTlBRDgyNUUKUldSZWdxM3BYU2ZwNnVLZlhscVJkRVdVa25ub2FwMWhRcDdLaDJTcEhLdE5TcUZDaVJwK2ZqakUK",
      "endpoints": [
        "https://raw.githubusercontent.com/Chetan302003/Aura-Hub/refs/heads/main/updater.json"
      ]
    }
  }
}